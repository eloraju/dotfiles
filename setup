#!/usr/bin/env bash
# run in bash to avoid issues with zsh not being installed yet

# make sure some directories exist so they don't
# point to this repo
# e.g. ~/.local/share/zsh/history is someting that shouldn't end up
# in github

function create_dirs() {
  [ -d "$HOME/.local/share/zsh" ] || mkdir -p "$HOME/.local/share/zsh"
  [ -d "$HOME/.local/user/scripts" ] || mkdir -p "$HOME/.local/share/scripts"
}

function remove_dotfiles() {
  stow --dotfiles -t "$HOME" --delete shared --delete $1
}

function set_dotfiles() {
  stow --dotfiles -t "$HOME" --stow shared --stow $1
}

function test_stow() {
  stow --simulate --dotfiles -t "$HOME" --stow shared --stow $1
}

delete_flag=
reset_flag=
test_flag=
while getopts drt option; do
  case $option in
  d) delete_flag=1 ;;
  r) reset_flag=1 ;;
  t) test_flag=1 ;;
  *) ;;
  esac
done

os=
install_cmd=
case $OSTYPE in
darwin*)
  echo "Detected macOS"
  os="mac"
  install_cmd="brew install"
  ;;
linux*)
  echo "Detected linux"
  os="linux"
  install_cmd="paru -S"
  [ -d "$HOME/.local/share/fonts" ] || mkdir -p "$HOME/.local/share/fonts"
  ;;
*)
  echo "What is this OS? '$OSTYPE'"
  exit 1
  ;;
esac

if ! test_stow $os; then
  echo "Conflicts with stow. Check above."
  exit 1
fi

if [ -n "$delete_flag" ]; then
  echo "Removing dotfiles"
  remove_dotfiles $os
  exit 0
fi

create_dirs

if [ -n "$reset_flag" ]; then
  echo "Resetting dotfiles"
  remove_dotfiles $os
fi

echo "Setting up dotfiles"
set_dotfiles $os

echo "Installing shared packages from ./pkgs"
$install_cmd $(cat ./pkgs | xargs)

if [ "$os" = "linux" ]; then
  echo "Installing linux spesific packages from ./pkgs-linux"
  $install_cmd $(cat ./pkgs-linux | xargs)
fi
