# Mac specific environment variables

eval "$(/opt/homebrew/bin/brew shellenv)"

# bun
export BUN_INSTALL=$HOME/.bun
PATH=$BUN_INSTALL/bin:$PATH

# Add intellij idea to path
PATH=/Applications/IntelliJ\ IDEA.app/Contents/MacOS:$HOME/Library/Application\ Support/JetBrains/Toolbox/scripts:$PATH

# Android studio stuff
export ANDROID_HOME="$HOME/Library/Android/sdk"

# Add android binaries
PATH=$ANDROID_HOME:$ANDROID_HOME/emulator:$ANDROID_HOME/tools:$ANDROID_HOME/tools/bin:$ANDROID_HOME/platform-tools:$PATH

