#!/usr/bin/env bash
# run in bash to avoid issues with zsh not being installed yet

# make sure some directories exist so they don't
# point to this repo
# e.g. ~/.local/share/zsh/history is someting that shouldn't end up
# in github

function create_dirs() {
  [ -d "$HOME/.local/share/zsh" ] || mkdir -p "$HOME/.local/share/zsh"
  [ -d "$HOME/.local/user/scripts" ] || mkdir -p "$HOME/.local/share/scripts"
}

delete_flag=
reset_flag=
while getopts dr option; do
  case $option in
  d) delete_flag=1 ;;
  r) reset_flag=1 ;;
  *) ;;
  esac
done

case $OSTYPE in
darwin*)
  if [ -n "$delete_flag" ]; then
    echo "Detected macOS. Removing macOS-specific dotfiles."
    stow --dotfiles -t "$HOME" -D shared -D mac
  elif [ -n "$reset_flag" ]; then
    echo "Detected macOS. Resetting macOS-specific dotfiles."
    stow --dotfiles -t "$HOME" -D shared -D mac
    create_dirs
    stow --dotfiles -t "$HOME" -S shared -S mac
  else
    echo "Detected macOS. Installing macOS-specific dotfiles."
    create_dirs
    stow --dotfiles -t "$HOME" shared mac
  fi
  ;;
linux*)
  [ -d "$HOME/.local/share/fonts" ] || mkdir -p "$HOME/.local/share/fonts"
  if [ -n "$delete_flag" ]; then
    echo "Detected Linux. Removing dotfiles"
    stow --dotfiles -t "$HOME" -D shared -D linux
  elif [ -n "$reset_flag" ]; then
    echo "Detected Linux. Resetting dotfiles"
    stow --dotfiles -t "$HOME" -D shared -D linux
    create_dirs
    stow --dotfiles -t "$HOME" -S shared -S linux
  else
    echo "Detected Linux. Installing dotfiles"
    create_dirs
    stow --dotfiles -t "$HOME" shared linux
  fi
  ;;
*)
  echo "What is this OS? '$OSTYPE'"
  exit 1
  ;;
esac
