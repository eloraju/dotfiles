#!/bin/sh

# make zsh read configs from ~/.config/zsh instead of ~/
export ZDOTDIR=$HOME/.config/zsh

export LOCAL_BIN=$HOME/.local/bin
export USER_BIN=$HOME/.local/user/bin
export SCRIPTS_DIR=$HOME/.local/user/scripts
LOCAL_BINS=$LOCAL_BIN:$USER_BIN:$SCRIPTS_DIR

# XDG DIRS
export XDG_CONFIG_HOME=$HOME/.config
export XDG_CACHE_HOME=$HOME/.local/cache
export XDG_DATA_HOME=$HOME/.local/share

# Rust packages
export CARGO_INSTALL_ROOT=$XDG_DATA_HOME/cargo
CARGO_BIN=$CARGO_INSTALL_ROOT/bin
RUSTPUP_BIN=$HOME/.cargo/bin
RUST_BINS=$CARGO_BIN:$RUSTPUP_BIN

# GnuPG
export GNUPGHOME=$XDG_DATA_HOME/gnupg

# nvim as editor
export VISUAL=nvim
export EDITOR=$VISUAL
export SUDO_EDITOR=$VISUAL

export KEYTIMEOUT=1

# History stuff
export HISTFILE="$HOME/.local/share/zsh/history"
export HISTSIZE=10000
export SAVEHIST=$HISTSIZE
#export MANPAGER="sh -c 'col -bx |bat -l man -p'"
export MANPAGER="nvim +Man!"

export NVM_DIR="$HOME/.nvm"

# source mac envs if running on mac
if [ "$(uname)" = "Darwin" ]; then
  source $HOME/.config/env_mac
fi

export PATH=$LOCAL_BINS:$RUST_BINS:$PATH
